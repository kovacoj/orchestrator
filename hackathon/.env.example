# hackathon/.env.example — copy to hackathon/.env and fill in.
# The root opencode.json explicitly denies reading .env* files, so secrets
# stay out of agent context.

# ────────────────────────────────────────────────────────────────────────
# Database (default: SQLite at hackathon/.data/marketwin.db)
# ────────────────────────────────────────────────────────────────────────
# Leave unset to use SQLite. Set to a postgresql:// URL to use Supabase /
# Postgres. Schema lives in hackathon/schema.sql.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT.supabase.co:5432/postgres

# ────────────────────────────────────────────────────────────────────────
# Apify (only needed when APIFY_MODE=live)
# ────────────────────────────────────────────────────────────────────────
APIFY_MODE=cached   # cached | live | off
# APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxx
# APIFY_ACTOR_ID=apify/web-scraper

# ────────────────────────────────────────────────────────────────────────
# API server
# ────────────────────────────────────────────────────────────────────────
# CORS_ORIGINS=*           # comma-separated; tighten before any public deploy
# MARKETWIN_API_PORT=8001

# ────────────────────────────────────────────────────────────────────────
# Provenance (informational — these are wired in opencode.json, not here)
# ────────────────────────────────────────────────────────────────────────
# Subagent runtime target:  siemens-sdc-openai-responses/gpt-5.3-codex
# Subagent reasoning level: medium
