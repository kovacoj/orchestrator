#!/usr/bin/env bash

set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  printf '%s\n' "pre-commit: gitleaks is required but not installed."
  printf '%s\n' "Install gitleaks and retry commit: https://github.com/gitleaks/gitleaks"
  exit 1
fi

printf '%s\n' "pre-commit: scanning staged changes for secrets..."

if gitleaks protect --help >/dev/null 2>&1; then
  gitleaks protect --staged --redact --no-banner
else
  gitleaks git --staged --redact --no-banner
fi

printf '%s\n' "pre-commit: gitleaks passed."
