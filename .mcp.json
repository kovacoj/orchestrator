{
  "mcpServers": {
    "apify": {
      "type": "http",
      "url": "https://mcp.apify.com"
    },
    "huggingface": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "app.mcp_servers.huggingface_server"
      ],
      "env": {
        "HF_MODE": "mock"
      }
    },
    "lovable": {
      "type": "http",
      "url": "YOUR_LOVABLE_MCP_URL",
      "headers": {
        "Authorization": "Bearer ${LOVABLE_TOKEN}"
      }
    },
    "n8n-local": {
      "type": "http",
      "url": "${N8N_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${N8N_MCP_TOKEN}"
      }
    }
  }
}
