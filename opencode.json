  // ════════════════════════════════════════════════════════════════
  //  MCP SERVERS
  // ════════════════════════════════════════════════════════════════
  "mcp": {
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com",
      "headers": {
        "Authorization": "Bearer {env:APIFY_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "signal-foundry-huggingface": {
      "type": "remote",
      "url": "{env:HF_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:HF_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "n8n-local": {
      "type": "remote",
      "url": "{env:N8N_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:N8N_MCP_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "signal-foundry-mcp": {
      "type": "remote",
      "url": "{env:SF_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:SF_MCP_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    }
  },

