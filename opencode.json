        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (1M ctx · Heavy Reasoning)",
          "attachment": false,
          "reasoning": true,
          "limit": {
            "context": 1048576,
            "output": 1048576
          }
        }
      }
    },

