  // ════════════════════════════════════════════════════════════════
  //  MCP SERVERS
  // ════════════════════════════════════════════════════════════════
  "mcp": {
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com",
      "headers": {
        "Authorization": "Bearer {env:APIFY_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "signal-foundry-huggingface": {
      "type": "remote",
      "url": "{env:HF_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:HF_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "lovable": {
      "type": "remote",
      "url": "{env:LOVABLE_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:LOVABLE_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    },
    "n8n-local": {
      "type": "remote",
      "url": "{env:N8N_MCP_URL}",
      "headers": {
        "Authorization": "Bearer {env:N8N_MCP_TOKEN}"
      },
      "oauth": false,
      "enabled": true
    }
  },

  "share": "disabled",

  "disabled_providers": [
    "opencode",
    // "openai"
  ],

  "permission": {
    "bash": {
      "rm -rf *": "deny",
      "rm -r /*": "deny",
      "sudo *": "deny",
      "git push *": "deny",
      "git push --force *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "nc *": "deny",
      "ncat *": "deny",
      "pip install *": "deny",
      "pip3 install *": "deny",
      "npm install *": "deny",
      "npm i *": "deny",
      "chmod 777 *": "deny",
      "chmod +x *": "deny",
      "chown *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "shutdown *": "deny",
      "reboot *": "deny",
      "poweroff *": "deny",
      "npm run lint": "allow",
      "npm run test *": "allow",
      "uv run *": "allow",
      "poetry run *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git stash *": "allow",
      "*": "ask"
    },
    "read": {
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "secrets/**": "deny",
      "**/secrets/**": "deny",
      "config/credentials.json": "deny",
      "**/credentials.json": "deny",
      "**/*.pem": "deny",
      "**/*.key": "deny",
      "**/*.p12": "deny",
      "**/*.pfx": "deny",
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.zshrc": "allow",
      "*": "allow"
    },
    "edit": "ask",
    "write": "ask",
    "webfetch": "ask",
    "websearch": "ask"
  },

  "plugin": [
    "./plugins/copilot-auth.mjs",
    "./plugins/siemens-guards.js",
    "./plugins/env-protection.js",
    "./plugins/my-guards.ts"
  ]
}
