  "permission": {
    "bash": {
      "rm -rf *": "deny",
      "rm -r /*": "deny",
      "sudo *": "deny",
      "git push *": "deny",
      "git push --force *": "deny",
      "ssh *": "deny",
      "scp *": "deny",
      "rsync *": "deny",
      "curl *": "deny",
      "wget *": "deny",
      "nc *": "deny",
      "ncat *": "deny",
      "pip install *": "deny",
      "pip3 install *": "deny",
      "npm install *": "deny",
      "npm i *": "deny",
      "chmod 777 *": "deny",
      "chmod +x *": "deny",
      "chown *": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "shutdown *": "deny",
      "reboot *": "deny",
      "poweroff *": "deny",
      "npm run lint": "allow",
      "npm run test *": "allow",
      "uv run *": "allow",
      "poetry run *": "allow",
      "git status": "allow",
      "git log *": "allow",
      "git diff *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git stash *": "allow",
      "*": "ask"
    },
    "read": {
      ".env": "deny",
      ".env.*": "deny",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "secrets/**": "deny",
      "**/secrets/**": "deny",
      "config/credentials.json": "deny",
